<%- include('partials/header', { user: user, user_type: user_type }); %>

<div class="container-fluid mt-5">

    <div class="card shadow p-4">

        <h1 class="mb-4 text-center">
            Admin Dashboard
        </h1>

        <table class="table table-striped">

            <thead>
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>User Type</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                <% users.forEach(u => { %>

                    <tr>

                        <td><%= u.username %></td>

                        <td><%= u.email %></td>

                        <td>
                            <%= u.user_type %>
                        </td>

                        <td>

                            <% if (u.user_type === "user") { %>

                                <a
                                   href="/promote/<%= u._id %>"
                                   class="btn btn-success btn-sm">
                                    Promote
                                </a>

                            <% } else { %>

                                <a
                                   href="/demote/<%= u._id %>"
                                   class="btn btn-danger btn-sm">
                                    Demote
                                </a>

                            <% } %>

                        </td>

                    </tr>

                <% }) %>

            </tbody>

        </table>

    </div>

</div>

<%- include('partials/footer', { user: user, user_type: user_type }); %>