<%- include("partials/header", {user: user, user_type: user_type}) %>
<div class="card shadow p-4 form-card">
    <h1 class="text-center mb-4">Log In</h1>

    <form method="post">
        <div class="mb-3">
            <input 
                name="email" 
                type="email" 
                class="form-control" 
                placeholder="Email"
            />
        </div>

        <div class="mb-3">
            <input 
                name="password" 
                type="password" 
                class="form-control" 
                placeholder="Password"
            />
        </div>

        <button type="submit" class="btn btn-primary w-100">Log In</button>
    </form>
</div>
<%- include("partials/footer", {user: user, user_type: user_type}) %>