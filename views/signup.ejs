<%- include("partials/header", {user: user, user_type: user_type}) %>

<div class="card shadow p-4 form-card">

    <h1 class="text-center mb-4">Sign Up</h1>

    <form method="post">

        <input
            class="form-control mb-3"
            name="username"
            type="text"
            placeholder="Username"
        >

        <input
            class="form-control mb-3"
            name="email"
            type="email"
            placeholder="Email"
        >

        <input
            class="form-control mb-3"
            name="password"
            type="password"
            placeholder="Password"
        >

        <button class="btn btn-primary w-100">
            Sign Up
        </button>

    </form>

</div>

<%- include("partials/footer", {user: user, user_type: user_type}) %>